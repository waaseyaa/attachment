{
    "name": "waaseyaa/attachment",
    "description": "Attachment content type with parent-entity reference and at-most-one-active invariant.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../database-legacy"
        },
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../entity-storage"
        },
        {
            "type": "path",
            "url": "../foundation"
        }
    ],
    "require": {
        "php": "^8.5",
        "symfony/http-foundation": "^7.0",
        "waaseyaa/access": "^0.1.0-alpha.251",
        "waaseyaa/database-legacy": "^0.1.0-alpha.251",
        "waaseyaa/entity": "^0.1.0-alpha.251",
        "waaseyaa/foundation": "^0.1.0-alpha.251"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "symfony/event-dispatcher": "^7.0",
        "waaseyaa/entity-storage": "^0.1.0-alpha.251"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Attachment\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Attachment\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "providers": [
                "Waaseyaa\\Attachment\\AttachmentServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
